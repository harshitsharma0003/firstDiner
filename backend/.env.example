# Copy to .env and adjust.
PORT=4000
JWT_SECRET=change-me-to-a-long-random-string

# 'memory' (default, runs instantly) or 'firestore' (production)
DATA_STORE=memory

# In dev the OTP is returned in the API response so you can test without SMS.
# Set to 'false' in production (and use Firebase Phone Auth on the client).
EXPOSE_OTP=true

# Platform admin seeded on first boot
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin123

# For Firestore (DATA_STORE=firestore):
# GOOGLE_APPLICATION_CREDENTIALS=./service-account.json
